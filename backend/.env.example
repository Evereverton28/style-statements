FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
# Leave DATABASE_URL unset to use the bundled SQLite file (database/style_statements.db)
# DATABASE_URL=postgresql://user:pass@localhost:5432/style_statements
CORS_ORIGINS=*

# M-Pesa Daraja (fill when going live; checkout simulates until then)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# Load the sample catalog on first run? Leave false for an empty store.
SEED_SAMPLE_DATA=false

# First-run super admin account (created once, on first startup)
ADMIN_NAME=
ADMIN_EMAIL=owner@stylestatements.co.ke
ADMIN_PASSWORD=changeme123
